{
  "name": "@pos/desktop",
  "private": true,
  "version": "1.0.0",
  "description": "POS System - Desktop Edition with offline SQLite storage",
  "author": "KT-Devv",
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev -c electron-vite.config.ts",
    "build": "electron-vite build -c electron-vite.config.ts",
    "build:win": "electron-vite build -c electron-vite.config.ts && electron-builder --win",
    "preview": "electron-vite preview -c electron-vite.config.ts"
  },
  "dependencies": {
    "@pos/shared": "*",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^2.5.2",
    "node-thermal-printer": "^4.6.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "33.4.11",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "~5.6.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.pos.desktop",
    "productName": "POS System",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "../../node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
